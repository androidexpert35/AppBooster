    <string name="shizuku_install_description">Shizuku è un’app gratuita e open source che permette ad altre app di eseguire comandi con privilegi elevati. Questo consente ad AppBooster di effettuare ottimizzazioni avanzate senza accesso root.\n\nDopo l’installazione, torna qui per continuare la configurazione.</string>
    <string name="shizuku_download_action">Scarica Shizuku</string>

    <string name="shizuku_start_service_title">Avvia il servizio Shizuku</string>
    <string name="shizuku_start_service_description">Shizuku è installato, ma il servizio non è in esecuzione. Devi avviarlo una volta usando uno di questi metodi:</string>

    <string name="shizuku_method_adb_title">Tramite ADB (consigliato)</string>
    <string name="shizuku_method_adb_instruction">Collega il dispositivo a un PC ed esegui:</string>
    <string name="shizuku_method_adb_command">adb shell sh /sdcard/Android/data/moe.shizuku.privileged.api/start.sh</string>

    <string name="shizuku_method_root_title">Tramite root</string>
    <string name="shizuku_method_root_description">Se il dispositivo è rootato, apri Shizuku e seleziona "Start via Root".</string>

    <string name="shizuku_grant_description">Shizuku è in esecuzione! Ora AppBooster ha bisogno del permesso per usarlo. Tocca il pulsante qui sotto e consenti l’accesso nella finestra di dialogo di Shizuku.</string>
    <string name="shizuku_grant_requesting">Richiesta in corso...</string>

